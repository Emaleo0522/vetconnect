# Database
DATABASE_URL=postgresql://user:password@localhost:5432/vetconnect

# Server
PORT=3001
NODE_ENV=development

# CORS — comma-separated origins allowed
CORS_ORIGINS=http://localhost:8081

# Better Auth
BETTER_AUTH_SECRET=your-secret-key-min-16-chars

# Encryption key for sensitive data (e.g., QR tokens)
ENCRYPTION_KEY=your-encryption-key-min-16-chars
